{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts --port=3000 --host=0.0.0.0",
    "dev:all": "tsx backend/node/dev-runner.ts",
    "dev:all:bg": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev-all.ps1",
    "dev:all:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-dev-all.ps1",
    "service:py-platform": "python backend/python/run_server.py",
    "proxy": "tsx backend/node/binance-proxy.ts",
    "build": "vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['frontend/build','build','dist']) fs.rmSync(p, { recursive: true, force: true });\"",
    "lint": "tsc -p frontend/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "ccxt": "^4.5.44",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "kafkajs": "^2.2.4",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "redis": "^5.11.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
