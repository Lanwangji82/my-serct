{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:all": "tsx server/dev-runner.ts",
    "dev:all:bg": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-dev-all.ps1",
    "dev:all:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./stop-dev-all.ps1",
    "service:py-platform": "python python_services/run_server.py",
    "proxy": "tsx server/binance-proxy.ts",
    "service:market-ingest": "tsx server/market-ingest-service.ts",
    "service:market-query": "tsx server/market-query-service.ts",
    "service:account-gateway": "tsx server/account-gateway-service.ts",
    "service:risk": "tsx server/risk-service.ts",
    "service:alert": "tsx server/alert-service.ts",
    "service:research": "tsx server/research-service.ts",
    "service:portfolio": "tsx server/portfolio-service.ts",
    "service:governance": "tsx server/governance-service.ts",
    "bus:consumer": "tsx server/kafka-projection-consumer.ts",
    "stream:compute": "tsx server/stream-compute-worker.ts",
    "store:historical": "tsx server/clickhouse-persistence-worker.ts",
    "store:init": "echo Apply server/clickhouse-schema.sql to your ClickHouse database before running historical persistence",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "ccxt": "^4.5.44",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "kafkajs": "^2.2.4",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "redis": "^5.11.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
