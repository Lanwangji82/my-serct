# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# BINANCE_PROXY_PORT: Local proxy port for Binance REST/WS aggregation.
BINANCE_PROXY_PORT="8787"
PY_PLATFORM_PORT="8800"

# Local proxy support for Node and platform network requests.
# For Clash mixed-port defaults, the simplest working setup is usually:
# NODE_USE_ENV_PROXY="1"
# HTTP_PROXY="http://127.0.0.1:7890"
# HTTPS_PROXY="http://127.0.0.1:7890"
# NO_PROXY="127.0.0.1,localhost"
# Optional platform-specific overrides can be set below if needed.
# Important: proxy options are mutually exclusive.
# Pick only one primary route:
# - PLATFORM_SOCKS_PROXY
# - or PLATFORM_HTTPS_PROXY
# - or PLATFORM_HTTP_PROXY
NODE_USE_ENV_PROXY="1"
HTTP_PROXY=""
HTTPS_PROXY=""
ALL_PROXY=""
NO_PROXY="127.0.0.1,localhost"
PLATFORM_HTTP_PROXY=""
PLATFORM_HTTPS_PROXY=""
PLATFORM_SOCKS_PROXY=""
PLATFORM_WS_PROXY=""
PLATFORM_WSS_PROXY=""
# Network client routing for local sing-box / Clash style ports.
# Current local ports:
# 7890 auto
# 7891 jp
# 7892 sg
# 7893 us
# 7894 hk
# 7895 direct
# Broker defaults:
# Binance -> jp
# OKX -> auto
PLATFORM_CLIENT_ROUTE_DEFAULT="auto"
PLATFORM_CLIENT_ROUTE_BINANCE="jp"
PLATFORM_CLIENT_ROUTE_OKX="auto"
PLATFORM_CLIENT_AUTO_URL="http://127.0.0.1:7890"
PLATFORM_CLIENT_JP_URL="http://127.0.0.1:7891"
PLATFORM_CLIENT_SG_URL="http://127.0.0.1:7892"
PLATFORM_CLIENT_US_URL="http://127.0.0.1:7893"
PLATFORM_CLIENT_HK_URL="http://127.0.0.1:7894"
PLATFORM_CLIENT_DIRECT_URL="http://127.0.0.1:7895"
# Legacy compatibility variables. Prefer PLATFORM_* above.
CCXT_HTTP_PROXY=""
CCXT_HTTPS_PROXY=""
CCXT_SOCKS_PROXY=""
CCXT_WS_PROXY=""
CCXT_WSS_PROXY=""
CCXT_TIMEOUT_MS="10000"

# Public market data driver.
# - ccxt: route REST market data and orderbook snapshots through ccxt
# - binance: use direct Binance REST endpoints
# For fast Kline switching on Binance, `binance` is the safer default.
MARKET_DATA_DRIVER="binance"
VITE_MARKET_DATA_DRIVER="binance"

# Optional Clash controller integration for startup proxy optimization.
# Set CLASH_AUTO_OPTIMIZE="1" to benchmark the selector group against exchange APIs
# before trading requests start flowing, then switch the selector to the best node.
CLASH_CONTROLLER_URL="http://127.0.0.1:9090"
CLASH_SECRET=""
CLASH_SELECTOR_GROUP="🚀节点选择"
CLASH_BINANCE_TEST_URL="https://api.binance.com/api/v3/ping"
CLASH_OKX_TEST_URL="https://www.okx.com/api/v5/public/time"
CLASH_DELAY_TIMEOUT_MS="4000"
CLASH_AUTO_OPTIMIZE="0"
CLASH_AUTO_OPTIMIZE_EXCHANGES="binance,okx"

# CACHE_DRIVER: Cache driver for the local proxy.
# Supported values:
# - memory: single-process in-memory cache
# - redis: Redis-backed cache with in-memory fallback if Redis is unavailable
CACHE_DRIVER="memory"

# REDIS_URL: Redis connection URL used when CACHE_DRIVER=redis.
REDIS_URL="redis://127.0.0.1:6379"

# MESSAGE_BUS_DRIVER: Message bus backend for the local proxy.
# Supported values:
# - none: disable message bus publishing
# - kafka: publish hot market/account/orderbook/indicator events to Kafka
MESSAGE_BUS_DRIVER="none"

# KAFKA_BROKERS: Comma-separated Kafka broker list used when MESSAGE_BUS_DRIVER=kafka.
KAFKA_BROKERS="127.0.0.1:9092"

# KAFKA_CLIENT_ID: Kafka client id for this proxy instance.
KAFKA_CLIENT_ID="quantx-proxy"

# HISTORICAL_STORE_DRIVER: Historical storage backend.
# Supported values:
# - none: disable historical persistence
# - clickhouse: enable ClickHouse persistence worker/storage adapter
HISTORICAL_STORE_DRIVER="none"

# CLICKHOUSE_URL: ClickHouse HTTP endpoint.
CLICKHOUSE_URL="http://127.0.0.1:8123"

# CLICKHOUSE_USER: ClickHouse username.
CLICKHOUSE_USER="default"

# CLICKHOUSE_PASSWORD: ClickHouse password.
CLICKHOUSE_PASSWORD=""

# CLICKHOUSE_DATABASE: ClickHouse database for QuantX historical tables.
CLICKHOUSE_DATABASE="quantx"

# KAFKA_TOPIC_PREFIX: Topic namespace prefix for QuantX events.
KAFKA_TOPIC_PREFIX="quantx"

# Platform bootstrap auth and secret storage.
AUTH_BOOTSTRAP_EMAIL="admin@quantx.local"
AUTH_BOOTSTRAP_PASSWORD="quantx-admin"
SECRET_STORE_KEY="replace-with-a-long-random-secret"
PY_PLATFORM_DB_PATH=""
PY_PLATFORM_STRATEGY_STORE=""
PY_PLATFORM_LOCAL_MODE="1"

# Optional semantic retrieval backend.
# Leave disabled to use the built-in local hybrid retriever.
# Enable and point to a remote Milvus endpoint to switch the same API onto vector search.
MILVUS_ENABLED="0"
MILVUS_URI=""
MILVUS_TOKEN=""
MILVUS_COLLECTION_MARKET_INTELLIGENCE="market_intelligence"

# Flink / stream-compute integration placeholders.
FLINK_ENABLED="false"
FLINK_REST_URL="http://127.0.0.1:8081"
FLINK_JOB_JAR=""
FLINK_JOB_PARALLELISM="1"
